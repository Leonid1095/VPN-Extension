{
  "manifest_version": 3,
  "name": "PLGames Connect",
  "short_name": "PLGames Connect",
  "version": "2.3.0",
  "description": "Network profile manager for PLGames players. Manage HTTPS / SOCKS proxy profiles in one click.",
  "author": "PLGames",
  "permissions": [
    "storage",
    "proxy",
    "webRequest",
    "webRequestAuthProvider",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PLGames Connect",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
