# PLGames Connect backend — пример переменных окружения.
# Скопируй в .env и подставь реальные значения. .env в .gitignore.

# Сервер
PORT=8080
HOST=0.0.0.0
PUBLIC_URL=https://api.plgames.example          # внешний URL бэкенда (для возвращаемых ссылок)

# Безопасность
JWT_SECRET=replace-me-with-32-bytes-of-random   # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# DonatePay
DONATEPAY_USER_ID=                               # ID получателя на DonatePay
DONATEPAY_API_KEY=                               # API-ключ из личного кабинета DonatePay
DONATEPAY_WEBHOOK_SECRET=                        # секрет для проверки подписи вебхука
DONATEPAY_WEBHOOK_PATH=/api/donatepay/webhook    # URL который вписывается в настройках DonatePay

# Где жить ссылке на оплату (формируем сами):
# https://donate.qiwi.com/payin/<DONATEPAY_USERNAME>
DONATEPAY_USERNAME=

# Возврат пользователя после оплаты — landing /thanks?order=<id>
SUCCESS_URL=https://buy.plgames.example/thanks

# Прокси-пул (минимум один сервер на старте)
PROXY_POOL_FILE=./data/proxy-pool.json

# Internal API — для агента-синхронизатора на прокси-серверах.
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Этот токен ставится в env агента на прокси-сервере. Если пустой — internal API отключён.
INTERNAL_API_TOKEN=
